# =============================================================================
# Enterprise RAG AI Agent — Environment Variables Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git — it is already in .gitignore
#
# RULE: Every key in this file must match a field in app/core/config.py.
#       When a new phase adds new config fields, update both files together.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PROJECT_NAME="Enterprise RAG AI Agent"
API_V1_STR="/api/v1"
ENVIRONMENT="development"          # development | staging | production

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="INFO"                   # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# CORS — allowed frontend origins (comma-separated)
# ---------------------------------------------------------------------------
BACKEND_CORS_ORIGINS="http://localhost:3000"

# ---------------------------------------------------------------------------
# Database (Phase 1B — PostgreSQL 17, asyncpg driver)
# ---------------------------------------------------------------------------
# asyncpg is required. Do NOT use psycopg2 URLs (postgresql:// will not work).
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
#
# SECURITY: Replace <your_password> with your real password in .env only.
#           Never put a real password in this file.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql+asyncpg://postgres:<your_password>@localhost:5432/enterprise_ai_assistant"

# ---------------------------------------------------------------------------
# Phase 2 (Authentication) — uncomment after Phase 2 is implemented
# ---------------------------------------------------------------------------
# SECRET_KEY="your-secret-key-minimum-32-characters-long"
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# ALGORITHM="HS256"

# ---------------------------------------------------------------------------
# Phase 7 (Embedding) — uncomment after Phase 7 is implemented
# ---------------------------------------------------------------------------
# OPENAI_API_KEY="your-openai-api-key-here"

# ---------------------------------------------------------------------------
# Phase 8 (Qdrant) — uncomment after Phase 8 is implemented
# ---------------------------------------------------------------------------
# QDRANT_HOST="localhost"
# QDRANT_PORT=6333
# QDRANT_API_KEY=""

# ---------------------------------------------------------------------------
# Phase 10 (Claude) — uncomment after Phase 10 is implemented
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY="your-anthropic-api-key-here"